{
    "version": 2,
    "buildCommand": "pnpm run build",
    "outputDirectory": ".",
    "functions": {
        "dist/main.js": {
            "maxDuration": 30,
            "includeFiles": "dist/**"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "dist/main.js"
        }
    ]
}