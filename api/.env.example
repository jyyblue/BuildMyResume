# Server port
PORT=4000

# Production frontend URL (for CORS) — REQUIRED in production
FRONTEND_URL=https://buildmyresume.live

# Note: This API uses Puter.js for AI inference.
# Auth tokens are passed per-request from the frontend.
# No API keys are needed on the backend!

# E2E Encryption (set to true in production)
# SHARED_SECRET must match frontend's VITE_SHARED_SECRET
SHARED_SECRET=your-shared-secret-key-here
ENABLE_ENCRYPTION=false

# Gemini API (for AI content enhancement)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Supabase (for publishing resumes)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key